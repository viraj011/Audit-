# ── DB config reader ─────────────────────────────────────────────────────────
def read_db_config():
    cfg = {"host":"127.0.0.1","port":3306,"name":"qats","user":"root","pass":""}
    path = os.path.join(HERE, "..", "config", "db.php")
    try:
        txt = open(path, encoding="utf-8", errors="ignore").read()
        def g(k, d):
            m = re.search(r"define\(\s*'%s'\s*,\s*'([^']*)'\\s*\)" % k, txt)
            if not m: m = re.search(r"const\s+%s\s*=\s*'([^']*)'" % k, txt)
            return m.group(1) if m else d
        cfg["host"] = g("DB_HOST", cfg["host"])
        cfg["name"] = g("DB_NAME", cfg["name"])
        cfg["user"] = g("DB_USER", cfg["user"])
        cfg["pass"] = g("DB_PASS", cfg["pass"])
        pm = re.search(r"(?:define\(\s*'DB_PORT'\s*,\s*'?|const\s+DB_PORT\s*=\s*'?)(\d+)", txt)
        if pm: cfg["port"] = int(pm.group(1))
    except Exception: pass
    return cfg

def get_conn(cfg):
    return pymysql.connect(
        host=cfg["host"], port=cfg["port"], user=cfg["user"],
        password=cfg["pass"], database=cfg["name"], charset="utf8mb4",
        cursorclass=pymysql.cursors.DictCursor)

def iso_week(dt):
    y, w, _ = dt.isocalendar(); return y * 100 + w

# ── data loader ───────────────────────────────────────────────────────────────
def load_all(c):
    def q(sql, cols):
        cur = c.cursor(); cur.execute(sql); raw = cur.fetchall(); cur.close()
        if not raw: return pd.DataFrame(columns=cols)
        first = raw[0]
        if isinstance(first, dict): rows = [{col: r.get(col) for col in cols} for r in raw]
        elif hasattr(first, "keys"): rows = [{col: r[col] for col in cols} for r in raw]
        else: rows = [dict(zip(cols, r)) for r in raw]
        return pd.DataFrame(rows, columns=cols)

    audits = q(
        "SELECT id,gen_id,operator,line,model,shift,audit_type,"
        "ng_count,total_checks,pass_rate,created_at FROM audits",
        ["id","gen_id","operator","line","model","shift","audit_type",
         "ng_count","total_checks","pass_rate","created_at"])

    results = q(
        "SELECT ar.audit_id,ar.param,ar.stage,ar.result,ar.ctq,"
        "a.line,a.model,a.shift,a.operator,a.created_at "
        "FROM audit_results ar JOIN audits a ON a.id=ar.audit_id",
        ["audit_id","param","stage","result","ctq","line","model",
         "shift","operator","created_at"])

    ncs = q(
        "SELECT id,audit_id,line,stage,severity,status,opened_at "
        "FROM nonconformities",
        ["id","audit_id","line","stage","severity","status","opened_at"])

    # coerce types
    for col in ["ng_count","total_checks"]:
        audits[col] = pd.to_numeric(audits[col], errors="coerce").fillna(0).astype(int)
    audits["pass_rate"] = pd.to_numeric(audits["pass_rate"], errors="coerce").fillna(100.0)
    if not results.empty:
        results["ctq"] = pd.to_numeric(results["ctq"], errors="coerce").fillna(0).astype(int)
    for df, col in [(audits,"created_at"),(results,"created_at"),(ncs,"opened_at")]:
        if not df.empty:
            df[col] = pd.to_datetime(df[col], errors="coerce")

    return audits, results, ncs


# ═══════════════════════════════════════════════════════════════════════════════
#  MODEL 1 — LINE RISK  (Random Forest Classifier, 3-class)
# ═══════════════════════════════════════════════════════════════════════════════
def build_line_risk(audits, results, ncs, anchor):
    """
    Per line, per week: engineer 12 features → label next week's risk class.
    Risk class: 0=Low (ng<3), 1=Medium (3-7), 2=High (>7)
    """
    ng_res = results[results["result"]=="NG"].copy() if not results.empty else pd.DataFrame()
    aud    = audits.copy()

    # add week column
    aud["wk"] = aud["created_at"].apply(iso_week)
    if not ng_res.empty:
        ng_res["wk"] = ng_res["created_at"].apply(iso_week)

    all_weeks = sorted(aud["wk"].unique())
    lines     = sorted(aud["line"].unique())

    # open NC map: line → count
    open_nc = {}
    if not ncs.empty:
        open_nc = ncs[ncs["status"]=="open"].groupby("line").size().to_dict()

    # severity score: critical=4, high=3, medium=2, low=1
    sev_map = {"critical":4,"high":3,"medium":2,"low":1}
    sev_score = {}
    if not ncs.empty:
        for ln, grp in ncs.groupby("line"):
            sev_score[ln] = sum(sev_map.get(str(s).lower(), 1) for s in grp["severity"])

    def risk_class(ng_count):
        if ng_count > 7:  return 2
        if ng_count > 2:  return 1
        return 0

    def rolling_feature(series, n, fn):
        """Apply fn to a sliding window of length n."""
        if len(series) < n:
            return fn(series) if series else 0.0
        return fn(series[-n:])

    training_rows = []
    line_weekly   = {}   # cache for prediction

    for ln in lines:
        la = aud[aud["line"]==ln].sort_values("wk")
        if la.empty: continue
        wks = sorted(la["wk"].unique())

        wk_data = {}
        for wk in wks:
            wa = la[la["wk"]==wk]
            n_audits = len(wa)
            ng_sum   = int(wa["ng_count"].sum())
            pass_avg = float(wa["pass_rate"].mean()) if n_audits else 100.0
            ctq_ng   = 0
            if not ng_res.empty:
                wng = ng_res[(ng_res["line"]==ln)&(ng_res["wk"]==wk)]
                ctq_ng = int((wng["ctq"]==1).sum())
            wk_data[wk] = {"ng":ng_sum,"audits":n_audits,"pass":pass_avg,"ctq":ctq_ng}

        line_weekly[ln] = wk_data
        wk_list = sorted(wk_data.keys())

        for i in range(4, len(wk_list)-1):
            w     = wk_list[i]
            w_nxt = wk_list[i+1]
            hist  = [wk_data[wk_list[j]]["ng"] for j in range(max(0,i-7), i+1)]
            h4    = hist[-4:] if len(hist)>=4 else hist
            h8    = hist[-8:] if len(hist)>=8 else hist

            f_ng_mean  = float(np.mean(h4))
            f_ng_std   = float(np.std(h4)) if len(h4)>1 else 0.0
            f_ng_max   = float(max(h4))
            # exponential weighted mean (more recent = more weight)
            f_ewm      = float(pd.Series(h4).ewm(span=3).mean().iloc[-1]) if h4 else 0.0
            f_ctq_rate = float(wk_data[w]["ctq"] / max(1, wk_data[w]["ng"])) if wk_data[w]["ng"] else 0.0
            f_pass     = wk_data[w]["pass"]
            f_aud_freq = float(wk_data[w]["audits"])
            # variance over 8 weeks (instability signal)
            f_variance = float(np.var(h8)) if len(h8)>1 else 0.0
            # trend: slope of last 4 weeks (normalised)
            x4 = np.arange(len(h4), dtype=float)
            f_slope = float(np.polyfit(x4, h4, 1)[0]) if len(h4)>1 else 0.0
            f_open_nc  = float(open_nc.get(ln, 0))
            f_sev      = float(sev_score.get(ln, 0))
            # consecutive high weeks streak
            streak = 0
            for v in reversed(h4):
                if v > 3: streak += 1
                else: break
            f_streak = float(streak)

            target_ng   = wk_data[w_nxt]["ng"]
            target_class= risk_class(target_ng)

            training_rows.append([
                f_ng_mean, f_ng_std, f_ng_max, f_ewm, f_ctq_rate,
                f_pass, f_aud_freq, f_variance, f_slope,
                f_open_nc, f_sev, f_streak,
                target_class, target_ng, ln
            ])

    feat_names = ["ng_mean","ng_std","ng_max","ewm","ctq_rate",
                  "pass_rate","aud_freq","variance","slope",
                  "open_nc","severity","streak"]

    model_info = {"model":"trend-fallback","cv_accuracy":None,"feature_importances":{}}
    clf = None

    if len(training_rows) >= 30:
        df_tr = pd.DataFrame(training_rows,
                             columns=feat_names+["target_class","target_ng","line"])
        X = df_tr[feat_names].values.astype(float)
        y = df_tr["target_class"].values

        # Attempt RandomForestClassifier with cross-validation
        try:
            clf = RandomForestClassifier(
                n_estimators=300,
                max_depth=6,
                min_samples_leaf=3,
                max_features="sqrt",
                class_weight="balanced",
                random_state=42,
                n_jobs=-1
            )
            clf.fit(X, y)
            # CV accuracy (stratified 3-fold if enough data, else 2-fold)
            k = 3 if len(training_rows) >= 60 else 2
            cv_scores = cross_val_score(clf, X, y, cv=k, scoring="accuracy")
            model_info["model"] = "RandomForestClassifier"
            model_info["cv_accuracy"] = round(float(cv_scores.mean()), 3)
            model_info["feature_importances"] = dict(
                zip(feat_names, [round(float(v),4) for v in clf.feature_importances_])
            )
        except Exception:
            # Fallback to ExtraTrees (lighter, works with tiny datasets)
            try:
                clf = ExtraTreesClassifier(
                    n_estimators=200, max_depth=5, random_state=42)
                clf.fit(X, y)
                model_info["model"] = "ExtraTreesClassifier"
            except Exception:
                clf = None

    # ── Predict current risk for each line ────────────────────────────────
    output = []
    stage_breakdown = {}

    for ln in lines:
        wk_data = line_weekly.get(ln, {})
        if not wk_data: continue
        wk_list = sorted(wk_data.keys())
        hist    = [wk_data[w]["ng"] for w in wk_list]
        h4      = hist[-4:] if len(hist)>=4 else hist
        h8      = hist[-8:] if len(hist)>=8 else hist

        f_ng_mean  = float(np.mean(h4)) if h4 else 0.0
        f_ng_std   = float(np.std(h4))  if len(h4)>1 else 0.0
        f_ng_max   = float(max(h4))     if h4 else 0.0
        f_ewm      = float(pd.Series(h4).ewm(span=3).mean().iloc[-1]) if h4 else 0.0
        cur        = wk_data[wk_list[-1]] if wk_list else {}
        f_ctq_rate = float(cur.get("ctq",0)/max(1,cur.get("ng",1))) if cur.get("ng",0) else 0.0
        f_pass     = float(cur.get("pass",100.0))
        f_aud_freq = float(cur.get("audits",0))
        f_variance = float(np.var(h8)) if len(h8)>1 else 0.0
        x4 = np.arange(len(h4), dtype=float)
        f_slope    = float(np.polyfit(x4,h4,1)[0]) if len(h4)>1 else 0.0
        f_open_nc  = float(open_nc.get(ln,0))
        f_sev      = float(sev_score.get(ln,0))
        streak     = 0
        for v in reversed(h4):
            if v > 3: streak+=1
            else: break
        f_streak   = float(streak)

        fv = np.array([[f_ng_mean,f_ng_std,f_ng_max,f_ewm,f_ctq_rate,
                        f_pass,f_aud_freq,f_variance,f_slope,
                        f_open_nc,f_sev,f_streak]])

        if clf is not None:
            proba     = clf.predict_proba(fv)[0]
            # proba indices match clf.classes_
            classes   = list(clf.classes_)
            p_low     = float(proba[classes.index(0)]) if 0 in classes else 0.0
            p_med     = float(proba[classes.index(1)]) if 1 in classes else 0.0
            p_high    = float(proba[classes.index(2)]) if 2 in classes else 0.0
            pred_class= int(clf.predict(fv)[0])
        else:
            # heuristic fallback
            avg = f_ng_mean
            if avg > 7:   pred_class=2; p_high=0.75; p_med=0.20; p_low=0.05
            elif avg > 2: pred_class=1; p_high=0.20; p_med=0.65; p_low=0.15
            else:         pred_class=0; p_high=0.05; p_med=0.15; p_low=0.80

        # 0-100 risk score from weighted probability
        risk_score = int(round(p_low*15 + p_med*55 + p_high*100))
        risk_label = ["Low","Medium","High"][pred_class]

        # trend
        slope_v = f_slope
        trend    = "up" if slope_v>0.5 else ("down" if slope_v<-0.5 else "flat")
        trend_pct= int(round(slope_v/max(1.0,f_ng_mean)*100)) if f_ng_mean else 0

        # stage breakdown from recent results
        recent_cut = anchor - pd.Timedelta(days=42)
        if not ng_res.empty:
            ln_ng = ng_res[(ng_res["line"]==ln)&(ng_res["created_at"]>=recent_cut)]
            if not ln_ng.empty:
                stg = ln_ng.groupby("stage").size().reset_index(name="ng").sort_values("ng",ascending=False)
                total_stage_ng = int(stg["ng"].sum())
                sb = []
                for _, row in stg.iterrows():
                    share = row["ng"]/max(1,total_stage_ng)
                    sb.append({"stage":row["stage"],"ng":int(row["ng"]),
                               "risk":int(round(min(100,share*100+risk_score*0.25)))})
                stage_breakdown[ln] = sb
            else:
                stage_breakdown[ln] = []
        else:
            stage_breakdown[ln] = []

        predicted_ng = round(f_ewm + f_slope, 1)  # EWM + slope as next-week estimate

        output.append({
            "line":       ln,
            "risk":       risk_score,
            "risk_label": risk_label,
            "predicted_ng": max(0.0, round(predicted_ng,1)),
            "ng_rate":    round(f_ng_mean/max(1,f_aud_freq)*100,2) if f_aud_freq else 0.0,
            "trend":      trend,
            "trend_pct":  trend_pct,
            "open_ncs":   int(open_nc.get(ln,0)),
            "ctq_ng":     int(cur.get("ctq",0)),
            "top_stage":  stage_breakdown[ln][0]["stage"] if stage_breakdown.get(ln) else "—",
            "prob_low":   round(p_low,3),
            "prob_med":   round(p_med,3),
            "prob_high":  round(p_high,3),
        })

    output.sort(key=lambda r: r["risk"], reverse=True)
    return output, stage_breakdown, model_info


# ═══════════════════════════════════════════════════════════════════════════════
#  MODEL 2 — NC FORECAST  (Holt-Winters Exponential Smoothing)
# ═══════════════════════════════════════════════════════════════════════════════
def nc_forecast(ncs, horizon=6):
    """
    Holt-Winters with additive trend + additive seasonal (period=4).
    Falls back to double exponential (trend only) if <8 weeks of data.
    Confidence bands via residual bootstrap (1000 samples).
    """
    if ncs.empty:
        return _empty_forecast(horizon)

    n = ncs.copy()
    n["wk"] = n["opened_at"].apply(iso_week)
    weekly   = n.groupby("wk").size().reset_index(name="count").sort_values("wk")
    weekly   = weekly.tail(26).reset_index(drop=True)   # last 26 weeks max

    y    = weekly["count"].values.astype(float)
    m    = len(y)
    labs = ["W-%d" % (m-i-1) for i in range(m)]
    fut  = ["W+%d" % (i+1)   for i in range(horizon)]

    if m < 4:
        # Not enough data — flat forecast
        avg = float(np.mean(y)) if m else 0.0
        return {
            "labels": labs + fut,
            "actual": y.tolist() + [None]*horizon,
            "forecast": [None]*(m-1) + [round(avg,1)] + [round(avg,1)]*horizon,
            "lower_80": [], "upper_80": [], "lower_95": [], "upper_95": [],
            "confidence": 50, "mape": None, "next_week": int(round(avg)),
            "model": "flat-mean"
        }

    # Hold out last 2 weeks for MAPE validation
    train_y = y[:-2] if m >= 6 else y
    test_y  = y[-2:] if m >= 6 else np.array([])

    forecast_vals = None
    mape_val      = None
    model_used    = "trend-fallback"
    fitted_vals   = None

    # ── Try Holt-Winters (statsmodels) ────────────────────────────────────
    if HAS_STATSMODELS and m >= 8:
        try:
            # seasonal_periods=4 (monthly SMD cycle)
            hw = ExponentialSmoothing(
                train_y,
                trend="add",
                seasonal="add" if len(train_y) >= 8 else None,
                seasonal_periods=4,
                initialization_method="estimated"
            ).fit(optimized=True, use_brute=False)
            fitted_vals    = hw.fittedvalues
            refit_all      = ExponentialSmoothing(
                y,
                trend="add",
                seasonal="add" if m >= 8 else None,
                seasonal_periods=4,
                initialization_method="estimated"
            ).fit(optimized=True, use_brute=False)
            forecast_vals = refit_all.forecast(horizon)
            fitted_vals   = refit_all.fittedvalues

            if len(test_y) >= 2:
                test_pred = hw.forecast(2)
                mape_val  = float(np.mean(np.abs((test_y - test_pred) / np.maximum(test_y,1)))) * 100
                mape_val  = round(mape_val, 1)
            model_used = "HoltWinters(trend=add,seasonal=add,period=4)"
        except Exception:
            forecast_vals = None

    # ── Fallback: double exponential smoothing (trend, no season) ─────────
    if forecast_vals is None and m >= 4:
        try:
            alpha, beta = 0.4, 0.3
            # Initialise
            lvl = float(y[0]); trd = float(y[1]-y[0])
            lvls = []; trds = []
            for v in y:
                lvl_new = alpha*v + (1-alpha)*(lvl+trd)
                trd_new = beta*(lvl_new-lvl) + (1-beta)*trd
                lvl=lvl_new; trd=trd_new
                lvls.append(lvl); trds.append(trd)
            fitted_vals   = np.array(lvls)
            forecast_vals = np.array([max(0,lvl + (i+1)*trd) for i in range(horizon)])
            model_used    = "DoubleExponentialSmoothing"
        except Exception:
            pass

    # ── Final fallback: simple AR(1) ──────────────────────────────────────
    if forecast_vals is None:
        rho = 0.7
        last = float(y[-1])
        mean = float(np.mean(y))
        forecast_vals = np.array([max(0, mean + rho**i * (last-mean)) for i in range(1,horizon+1)])
        fitted_vals   = y.copy()
        model_used    = "AR1-mean-reversion"

    forecast_vals = np.clip(forecast_vals, 0, None)

    # ── Confidence bands via residual bootstrap ────────────────────────────
    residuals = y - np.clip(fitted_vals[:len(y)], 0, None)
    residuals_clean = residuals[~np.isnan(residuals)]
    lower_80, upper_80, lower_95, upper_95 = [], [], [], []

    if len(residuals_clean) >= 4:
        rng = np.random.default_rng(42)
        boot = np.zeros((1000, horizon))
        for b in range(1000):
            noise = rng.choice(residuals_clean, size=horizon, replace=True)
            boot[b] = np.clip(forecast_vals + noise, 0, None)
        lower_80 = np.percentile(boot, 10, axis=0).round(1).tolist()
        upper_80 = np.percentile(boot, 90, axis=0).round(1).tolist()
        lower_95 = np.percentile(boot, 2.5, axis=0).round(1).tolist()
        upper_95 = np.percentile(boot, 97.5, axis=0).round(1).tolist()

    # confidence: high if residuals are small relative to mean
    mean_y   = float(np.mean(y)) if len(y) else 1.0
    resid_sd = float(np.std(residuals_clean)) if len(residuals_clean) else mean_y
    confidence = int(max(55, min(90, 100 * (1 - resid_sd / max(mean_y, 0.1)))))

    actual_padded   = y.tolist() + [None]*horizon
    forecast_padded = [None]*(m-1) + [round(float(y[-1]),1)] + [round(float(v),1) for v in forecast_vals]

    return {
        "labels":     labs + fut,
        "actual":     actual_padded,
        "forecast":   forecast_padded,
        "lower_80":   [None]*m + lower_80,
        "upper_80":   [None]*m + upper_80,
        "lower_95":   [None]*m + lower_95,
        "upper_95":   [None]*m + upper_95,
        "confidence": confidence,
        "mape":       mape_val,
        "next_week":  int(round(float(forecast_vals[0]))) if len(forecast_vals) else 0,
        "model":      model_used,
    }

def _empty_forecast(horizon):
    return {"labels":[],"actual":[],"forecast":[],
            "lower_80":[],"upper_80":[],"lower_95":[],"upper_95":[],
            "confidence":0,"mape":None,"next_week":0,"model":"no-data"}


# ═══════════════════════════════════════════════════════════════════════════════
#  MODEL 3 — PARAMETER FAILURE RISK  (Random Forest per parameter)
# ═══════════════════════════════════════════════════════════════════════════════
def param_failure_risk(results, anchor, top=15):
    """
    For each (param, stage) pair, train a RandomForest on sliding-window features.
    Features: [ng_rate_4w, ng_std_4w, ctq_flag, consecutive_ng_weeks, days_since_ng]
    Label: did this param have NG in the following week? (binary)
    If insufficient data, fall back to frequency-based probability.
    """
    if results.empty: return []

    rec = results.copy()
    rec["wk"] = rec["created_at"].apply(iso_week)
    all_wks   = sorted(rec["wk"].unique())

    output = []

    for (param, stage), grp in rec.groupby(["param","stage"]):
        total = len(grp)
        if total < 5: continue
        ng_grp = grp[grp["result"]=="NG"]
        ng_cnt = len(ng_grp)
        if ng_cnt == 0: continue

        ctq   = int(grp["ctq"].max())
        wk_ng = grp.groupby("wk").apply(lambda g: 1 if (g["result"]=="NG").any() else 0)

        wk_list = sorted(wk_ng.index.tolist())
        if len(wk_list) < 3:
            # simple frequency
            rate     = ng_cnt / total
            prob     = min(0.95, rate * (1.5 if ctq else 1.0))
            reason   = "High NG frequency" if rate>0.3 else "Moderate NG rate"
            output.append(_hotspot_row(param,stage,ng_cnt,total,ctq,prob,reason,grp,anchor,"frequency"))
            continue

        # build sliding features
        rows = []
        for i in range(3, len(wk_list)-1):
            h4 = [wk_ng.get(wk_list[j],0) for j in range(max(0,i-3),i+1)]
            rate_4w  = float(np.mean(h4))
            std_4w   = float(np.std(h4)) if len(h4)>1 else 0.0
            consec   = 0
            for v in reversed(h4):
                if v==1: consec+=1
                else: break
            # days since last NG
            ng_dates = ng_grp["created_at"].dropna()
            if not ng_dates.empty:
                days_since = (anchor - ng_dates.max()).days
            else:
                days_since = 999
            rows.append([rate_4w, std_4w, float(ctq), float(consec),
                         min(float(days_since)/30.0, 10.0),
                         int(wk_ng.get(wk_list[i+1],0))])

        if len(rows) < 6:
            rate = ng_cnt / total
            prob = min(0.95, rate * (1.5 if ctq else 1.0))
            reason = "Insufficient history — frequency estimate"
            output.append(_hotspot_row(param,stage,ng_cnt,total,ctq,prob,reason,grp,anchor,"frequency"))
            continue

        df_p = pd.DataFrame(rows, columns=["rate_4w","std_4w","ctq","consec","days_since","label"])
        X_p  = df_p[["rate_4w","std_4w","ctq","consec","days_since"]].values
        y_p  = df_p["label"].values

        prob = None; model_used = "frequency"
        if y_p.sum() > 0:   # at least 1 positive example
            try:
                clf_p = RandomForestClassifier(
                    n_estimators=100, max_depth=4, min_samples_leaf=2,
                    class_weight="balanced", random_state=42)
                clf_p.fit(X_p, y_p)
                h4_cur = [wk_ng.get(wk_list[j],0) for j in range(max(0,len(wk_list)-4),len(wk_list))]
                ng_dates = ng_grp["created_at"].dropna()
                days_since = (anchor - ng_dates.max()).days if not ng_dates.empty else 999
                consec_cur = 0
                for v in reversed(h4_cur):
                    if v==1: consec_cur+=1
                    else: break
                fv_cur = np.array([[float(np.mean(h4_cur)),float(np.std(h4_cur)) if len(h4_cur)>1 else 0.0,
                                    float(ctq),float(consec_cur),min(float(days_since)/30.0,10.0)]])
                prob_arr = clf_p.predict_proba(fv_cur)[0]
                classes  = list(clf_p.classes_)
                prob     = float(prob_arr[classes.index(1)]) if 1 in classes else 0.0
                model_used = "RandomForest"
            except Exception:
                prob = None

        if prob is None:
            rate = ng_cnt / total
            prob = min(0.95, rate * (1.5 if ctq else 1.0))

        # reason phrase
        rate_pct = ng_cnt/total*100
        if prob > 0.75:   reason = "Very high failure probability"
        elif prob > 0.5:  reason = "Elevated risk — recent NGs trending up"
        elif ctq:         reason = "CTQ parameter — low tolerance"
        elif rate_pct>20: reason = "Historical NG rate >20%"
        else:             reason = "Moderate recurring NG"

        output.append(_hotspot_row(param,stage,ng_cnt,total,ctq,prob,reason,grp,anchor,model_used))

    output.sort(key=lambda r: r["fail_prob"], reverse=True)
    return output[:top]

def _hotspot_row(param, stage, ng, total, ctq, prob, reason, grp, anchor, model):
    rec45 = grp[grp["created_at"] >= anchor - pd.Timedelta(days=45)]
    wk_ng_45 = rec45.groupby(rec45["created_at"].dt.isocalendar().week)["result"]\
                    .apply(lambda s: 1 if (s=="NG").any() else 0).tolist() if not rec45.empty else []
    sl = 0.0
    if len(wk_ng_45) >= 2:
        x = np.arange(len(wk_ng_45), dtype=float)
        sl = float(np.polyfit(x, wk_ng_45, 1)[0])
    trend = "up" if sl>0.02 else ("down" if sl<-0.02 else "flat")
    return {
        "param":      param,
        "stage":      stage,
        "ng":         int(ng),
        "checks":     int(total),
        "ng_rate":    round(ng/max(total,1)*100, 1),
        "fail_prob":  round(min(prob,0.99), 3),
        "ctq":        bool(ctq),
        "trend":      trend,
        "reason":     reason,
        "model":      model,
    }


# ═══════════════════════════════════════════════════════════════════════════════
#  MODEL 4 — ANOMALY DETECTION  (Isolation Forest)
# ═══════════════════════════════════════════════════════════════════════════════
def anomaly_detection(audits, results):
    """
    Detects audits that are outliers in their line context.
    Features per audit: [ng_count, pass_rate, total_checks, ctq_ng_count]
    Returns top 10 most anomalous recent audits.
    """
    if audits.empty: return []

    a = audits.copy()
    if not results.empty:
        ctq_per_audit = results[results["ctq"]==1].groupby("audit_id").apply(
            lambda g: (g["result"]=="NG").sum()).reset_index(name="ctq_ng")
        a = a.merge(ctq_per_audit.rename(columns={"audit_id":"id"}), on="id", how="left")
        a["ctq_ng"] = a["ctq_ng"].fillna(0)
    else:
        a["ctq_ng"] = 0

    feats = ["ng_count","pass_rate","total_checks","ctq_ng"]
    Xf    = a[feats].fillna(0).values.astype(float)

    if len(Xf) < 10: return []

    try:
        iso = IsolationForest(n_estimators=200, contamination=0.08, random_state=42)
        iso.fit(Xf)
        scores  = iso.score_samples(Xf)   # lower = more anomalous
        a["anomaly_score"] = scores
        a["is_anomaly"]    = iso.predict(Xf)  # -1 = anomaly
        anomalies = a[a["is_anomaly"]==-1].sort_values("anomaly_score").head(10)
        out = []
        for _, row in anomalies.iterrows():
            out.append({
                "audit_code": str(row.get("id","")),
                "line":       str(row["line"]),
                "operator":   str(row.get("operator","")),
                "ng_count":   int(row["ng_count"]),
                "pass_rate":  round(float(row["pass_rate"]),1),
                "ctq_ng":     int(row["ctq_ng"]),
                "anomaly_score": round(float(row["anomaly_score"]),4),
                "created_at": str(row["created_at"])[:16],
            })
        return out
    except Exception:
        return []


# ═══════════════════════════════════════════════════════════════════════════════
#  MODEL 5 — SHIFT / OPERATOR / MODEL RISK MATRIX
# ═══════════════════════════════════════════════════════════════════════════════
def risk_matrix(audits):
    """
    For each dimension (shift, operator, model), compute:
      - mean NG per audit
      - NG rate (NGs / total checks)
      - audit count
      - risk score (0-100, normalised against the dimension max)
    Returns top 8 by risk in each dimension.
    No regression — pure groupby + normalisation.
    """
    if audits.empty:
        return {"shift":[], "operator":[], "model":[]}

    out = {}
    for dim in ["shift","operator","model"]:
        col = dim
        if col not in audits.columns: out[dim]=[]; continue
        grp = audits.groupby(col).agg(
            audits_count=("id","count"),
            total_ng=("ng_count","sum"),
            total_checks=("total_checks","sum"),
            mean_pass=("pass_rate","mean")
        ).reset_index()
        grp = grp[grp["audits_count"]>=3]   # need at least 3 audits
        if grp.empty: out[dim]=[]; continue
        grp["ng_per_audit"] = grp["total_ng"] / grp["audits_count"]
        grp["ng_rate_pct"]  = grp["total_ng"] / grp["total_checks"].replace(0,1) * 100
        max_ng_pa = grp["ng_per_audit"].max() or 1.0
        max_ng_rt = grp["ng_rate_pct"].max()  or 1.0
        grp["risk"] = ((grp["ng_per_audit"]/max_ng_pa)*60 +
                       (grp["ng_rate_pct"]/max_ng_rt)*40).round(0).astype(int)
        grp = grp.sort_values("risk", ascending=False).head(8)
        rows = []
        for _, r in grp.iterrows():
            rows.append({
                "label":       str(r[col]),
                "audits":      int(r["audits_count"]),
                "total_ng":    int(r["total_ng"]),
                "ng_per_audit":round(float(r["ng_per_audit"]),2),
                "ng_rate_pct": round(float(r["ng_rate_pct"]),1),
                "mean_pass":   round(float(r["mean_pass"]),1),
                "risk":        int(r["risk"]),
            })
        out[dim] = rows
    return out


