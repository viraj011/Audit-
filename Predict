#  MAIN
# ═══════════════════════════════════════════════════════════════════════════════
def main():
    cfg = read_db_config()

    # 1. Connect
    try:
        c = get_conn(cfg)
    except Exception as e:
        msg = str(e)
        hint = ("MySQL connection failed. Check host/port/password in config/db.php "
                "and ensure MySQL is running.")
        if "Access denied" in msg:
            hint = "MySQL rejected username/password. Check DB_PASS in config/db.php."
        elif "Unknown database" in msg:
            hint = "Database not found. Create 'qats' and import sql/qats_complete.sql."
        elif "Can't connect" in msg or "2003" in msg:
            hint = "Cannot reach MySQL. Start MySQL in XAMPP Control Panel."
        _emit({"error":"db_connection","detail":msg,"hint":hint,
               "using":{"host":cfg["host"],"port":cfg["port"],
                        "name":cfg["name"],"user":cfg["user"]}})
        sys.exit(1)

    # 2. Load
    try:
        audits, results, ncs = load_all(c)
    except Exception as e:
        _emit({"error":"load_failed","detail":str(e),
               "hint":"Could not read audit tables. Import sql/qats_complete.sql."})
        sys.exit(1)
    finally:
        try: c.close()
        except Exception: pass

    if audits is None or audits.empty:
        _emit({"error":"no_data","detail":"No audit records in the database.",
               "hint":"Run seed.php or record some audits first."})
        sys.exit(1)

    anchor = audits["created_at"].max()

    # 3. Run all models
    try:
        line_out, stage_bd, mdl_info = build_line_risk(audits, results, ncs, anchor)
        forecast                     = nc_forecast(ncs)
        hotspots                     = param_failure_risk(results, anchor, top=15)
        anomalies                    = anomaly_detection(audits, results)
        matrix                       = risk_matrix(audits)
    except Exception as e:
        import traceback
        _emit({"error":"compute_failed","detail":str(e),
               "trace":traceback.format_exc().splitlines()[-5:]})
        sys.exit(1)

    top = line_out[0] if line_out else None

    output = {
        "generated_at": datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "data_window": {
            "from":    audits["created_at"].min().strftime("%Y-%m-%d"),
            "to":      anchor.strftime("%Y-%m-%d"),
            "audits":  int(len(audits)),
            "results": int(len(results)),
            "ncs":     int(len(ncs)),
        },
        "model_info": {
            "line_risk":   mdl_info,
            "forecast":    {"model": forecast.get("model","?"), "mape": forecast.get("mape")},
            "hotspots":    "RandomForestClassifier per parameter",
            "anomaly":     "IsolationForest(contamination=0.08)",
            "risk_matrix": "GroupBy normalisation (shift/operator/model)",
            "statsmodels": HAS_STATSMODELS,
        },
        "kpis": {
            "highest_risk_line":       top["line"]       if top else "—",
            "highest_risk_score":      top["risk"]       if top else 0,
            "highest_risk_label":      top["risk_label"] if top else "—",
            "highest_risk_stage":      top["top_stage"]  if top else "—",
            "predicted_ncs_next_week": forecast.get("next_week", 0),
            "forecast_confidence":     forecast.get("confidence", 0),
            "lines_high_risk":         sum(1 for r in line_out if r["risk_label"]=="High"),
            "lines_trending_up":       sum(1 for r in line_out if r["trend"]=="up"),
            "top_hotspot":             hotspots[0]["param"]    if hotspots else "—",
            "top_hotspot_prob":        int(round(hotspots[0]["fail_prob"]*100)) if hotspots else 0,
            "anomalies_detected":      len(anomalies),
        },
        "line_risk":      line_out,
        "stage_breakdown":stage_bd,
        "param_hotspots": hotspots,
        "nc_forecast":    forecast,
        "anomalies":      anomalies,
        "risk_matrix":    matrix,
    }

    try:
        json.dump(output, open(OUT,"w"), indent=2, default=str)
    except Exception as e:
        _emit({"error":"write_failed","detail":str(e),
               "hint":"Cannot write ml/predictions.json — check folder permissions."})
        sys.exit(1)

    print(json.dumps({
        "ok":          True,
        "generated_at":output["generated_at"],
        "lines":       len(line_out),
        "hotspots":    len(hotspots),
        "anomalies":   len(anomalies),
        "forecast_model": forecast.get("model","?"),
        "line_model":  mdl_info["model"],
        "cv_accuracy": mdl_info.get("cv_accuracy"),
    }))


def _emit(payload):
    try:
        json.dump(payload, open(OUT,"w"), indent=2, default=str)
    except Exception:
        pass
    print(json.dumps(payload, default=str))


if __name__ == "__main__":
    main()
