<script>
function toggleDept(h) {
    var b = h.nextElementSibling;
    var c = h.querySelector('.fa-chevron-down,.fa-chevron-up');
    b.style.display = (b.style.display === 'none') ? '' : 'none';
    if (c) { c.classList.toggle('fa-chevron-down'); c.classList.toggle('fa-chevron-up'); }
}
function toggleAll(m) {
    document.querySelectorAll('.nc-chk').forEach(function(cb){ cb.checked = m.checked; });
    updateSelCount();
}
function updateSelCount() {
    var n = document.querySelectorAll('.nc-chk:checked').length;
    document.getElementById('selCount').textContent = '(' + n + ' selected)';
}
function openReject(id) {
    document.getElementById('rejectNcId').value = id;
    document.getElementById('rejectModal').classList.add('show');
    document.getElementById('rejectBackdrop').classList.add('show');
}
function closeReject() {
    document.getElementById('rejectModal').classList.remove('show');
    document.getElementById('rejectBackdrop').classList.remove('show');
}
setTimeout(function() {
    document.querySelectorAll('.alert-success').forEach(function(a) {
        a.style.transition = 'opacity .5s'; a.style.opacity = '0';
        setTimeout(function(){ a.remove(); }, 500);
    });
}, 4000);
</script>
