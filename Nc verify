<?php
/* ============================================================================
 *  nc_verify.php — QA / PQC Verification Queue
 *  ---------------------------------------------------------------------------
 *  Dedicated page showing every NC in 'in_review' status.
 *  Features:
 *    - Full RCA submitted by department is shown before verify/reject
 *    - Auditor who raised the NG is traced (audits.gen_id + audits.operator)
 *    - Single verify, single reject (with reason modal), bulk verify (checkboxes)
 *    - Verify All button for closing everything at once
 *    - Grouped by department, filterable by dept/block/line/stage
 *    - PQC/Admin only — others redirected to nc_rca.php
 * ===========================================================================*/
require_once __DIR__ . '/includes/auth.php';
require_once __DIR__ . '/includes/helpers.php';
require_once __DIR__ . '/includes/components.php';
require_once __DIR__ . '/includes/audit_functions.php';
requireLogin();

$db = db();
$me = currentUser();
$by = $me['name'] ?? $me['gen_id'] ?? 'QA';

/* ── PQC/Admin gate ──────────────────────────────────────────────────────── */
$userRole = strtolower($me['role'] ?? '');
$userDept = $me['department'] ?? '';
/* Also fall back to role_label department detection for old sessions */
if ($userDept === '') {
    $DEPTS = ['Production','Material','Maintenance','Programming','Quality'];
    foreach ($DEPTS as $d) {
        if (stripos($me['role_label'] ?? '', $d) !== false) { $userDept = $d; break; }
    }
}
$isPQC = !empty($me['can_admin'])
      || in_array($userRole, ['admin','pqc','quality','quality manager'], true)
      || in_array(strtolower($userDept), ['pqc','quality','qa'], true);

if (!$isPQC) {
    flash('Access denied — verification is for QA / PQC only.', 'error');
    header('Location: nc_rca.php');
    exit;
}

/* ── POST handlers ───────────────────────────────────────────────────────── */
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!csrf_check()) {
        flash('Session expired.', 'error');
        header('Location: nc_verify.php');
        exit;
    }

    $action = $_POST['action'] ?? '';

    /* ── Single verify ─────────────────────────────────────────────────── */
    if ($action === 'verify') {
        $ncId = (int)($_POST['nc_id'] ?? 0);
        if ($ncId > 0) {
            $db->prepare("UPDATE nonconformities SET status='closed', closed_at=NOW() WHERE id=?")
               ->execute([$ncId]);
            $row = $db->prepare(
                "SELECT n.stage, n.defect_type, a.audit_code
                 FROM nonconformities n
                 LEFT JOIN audits a ON a.id = n.audit_id
                 WHERE n.id = ? LIMIT 1");
            $row->execute([$ncId]);
            $row = $row->fetch();
            if ($row) {
                $db->prepare("UPDATE rca_entries SET status='closed'
                              WHERE audit_code=? AND stage=? AND param=?")
                   ->execute([$row['audit_code']??null, $row['stage'], $row['defect_type']]);
            }
            flash("NC #{$ncId} verified and closed.", 'success');
        }
        $qs = $_SERVER['QUERY_STRING'] ? '?' . $_SERVER['QUERY_STRING'] : '';
        header('Location: nc_verify.php' . $qs);
        exit;
    }

    /* ── Single reject ─────────────────────────────────────────────────── */
    if ($action === 'reject') {
        $ncId  = (int)($_POST['nc_id'] ?? 0);
        $reason = trim($_POST['reject_reason'] ?? '');
        if ($ncId > 0) {
            $db->prepare("UPDATE nonconformities SET status='open', closed_at=NULL WHERE id=?")
               ->execute([$ncId]);
            $row = $db->prepare(
                "SELECT n.stage, n.defect_type, a.audit_code
                 FROM nonconformities n
                 LEFT JOIN audits a ON a.id = n.audit_id
                 WHERE n.id = ? LIMIT 1");
            $row->execute([$ncId]);
            $row = $row->fetch();
            if ($row) {
                $note = ' [QA Rejected by ' . $by . ': ' . mb_substr($reason, 0, 200) . ']';
                $db->prepare(
                    "UPDATE rca_entries
                     SET status='open',
                         responsible = CONCAT(COALESCE(responsible,''), ?)
                     WHERE audit_code=? AND stage=? AND param=?")
                   ->execute([$note, $row['audit_code']??null, $row['stage'], $row['defect_type']]);
            }
            flash("NC #{$ncId} rejected — sent back to department.", 'warning');
        }
        $qs = $_SERVER['QUERY_STRING'] ? '?' . $_SERVER['QUERY_STRING'] : '';
        header('Location: nc_verify.php' . $qs);
        exit;
    }

    /* ── Bulk verify selected ──────────────────────────────────────────── */
    if ($action === 'bulk_verify') {
        $ids = array_filter(array_map('intval', (array)($_POST['nc_ids'] ?? [])));
        if ($ids) {
            $ph = implode(',', array_fill(0, count($ids), '?'));
            $db->prepare("UPDATE nonconformities SET status='closed', closed_at=NOW() WHERE id IN ($ph)")
               ->execute(array_values($ids));
            foreach ($ids as $id) {
                $row = $db->prepare(
                    "SELECT n.stage, n.defect_type, a.audit_code
                     FROM nonconformities n LEFT JOIN audits a ON a.id=n.audit_id
                     WHERE n.id=? LIMIT 1");
                $row->execute([$id]);
                $row = $row->fetch();
                if ($row) {
                    $db->prepare("UPDATE rca_entries SET status='closed'
                                  WHERE audit_code=? AND stage=? AND param=?")
                       ->execute([$row['audit_code']??null, $row['stage'], $row['defect_type']]);
                }
            }
            flash(count($ids) . ' NC(s) verified and closed.', 'success');
        }
        header('Location: nc_verify.php');
        exit;
    }

    /* ── Verify ALL in_review ──────────────────────────────────────────── */
    if ($action === 'verify_all') {
        $db->exec("UPDATE nonconformities SET status='closed', closed_at=NOW() WHERE status='in_review'");
        $db->exec("UPDATE rca_entries SET status='closed' WHERE status='in_progress'");
        flash('All submitted NCs verified and closed.', 'success');
        header('Location: nc_verify.php');
        exit;
    }
}

/* ── Filters ─────────────────────────────────────────────────────────────── */
$fDept  = trim($_GET['dept']  ?? '');
$fLine  = trim($_GET['line']  ?? '');
$fBlock = trim($_GET['block'] ?? '');
$fStage = trim($_GET['stage'] ?? '');

/* ── Main query: all in_review NCs + RCA + auditor trace ─────────────────── */
$where  = ["n.status = 'in_review'"];
$params = [];
if ($fDept) {
    $where[] = "EXISTS (SELECT 1 FROM audit_results ar2
                        WHERE ar2.audit_id=n.audit_id AND ar2.stage=n.stage
                          AND ar2.result='NG' AND ar2.department=?)";
    $params[] = $fDept;
}
if ($fLine)  { $where[] = 'n.line = ?';  $params[] = $fLine; }
if ($fBlock) { $where[] = 'a.block = ?'; $params[] = $fBlock; }
if ($fStage) { $where[] = 'n.stage = ?'; $params[] = $fStage; }

$wSQL = implode(' AND ', $where);

/* Primary query with correlated subquery for audit_results (no ORDER BY in JOIN ON) */
$ncs = [];
try {
    $st = $db->prepare("
        SELECT
            n.*,
            a.audit_code,
            a.gen_id   AS auditor_gen_id,
            a.operator AS auditor_name,
            a.model, a.shift, a.block AS audit_block,
            a.created_at AS audit_date,
            ar.department, ar.remark AS ng_remark, ar.spec, ar.value AS ng_value,
            r.id               AS rca_id,
            r.root_cause,
            r.corrective_action,
            r.responsible,
            r.defect_desc,
            r.due_date         AS rca_due,
            r.period_type,
            r.created_by       AS rca_submitted_by
        FROM nonconformities n
        LEFT JOIN audits a ON a.id = n.audit_id
        LEFT JOIN audit_results ar ON ar.id = (
            SELECT ar2.id FROM audit_results ar2
            WHERE ar2.audit_id = n.audit_id
              AND ar2.stage    = n.stage
              AND ar2.result   = 'NG'
            ORDER BY ar2.id ASC LIMIT 1
        )
        LEFT JOIN (
            SELECT re.*,
                   ROW_NUMBER() OVER
                       (PARTITION BY re.audit_code, re.stage, re.param
                        ORDER BY re.id DESC) AS rn
            FROM rca_entries re
        ) r ON r.audit_code = a.audit_code
            AND r.stage = n.stage
            AND r.param = n.defect_type
            AND r.rn = 1
        WHERE $wSQL
        ORDER BY n.opened_at ASC
    ");
    $st->execute($params);
    $ncs = $st->fetchAll();
} catch (Throwable $e) {
    /* MySQL < 8 fallback — no ROW_NUMBER */
    try {
        $st2 = $db->prepare("
            SELECT n.*,
                   a.audit_code, a.gen_id AS auditor_gen_id, a.operator AS auditor_name,
                   a.model, a.shift, a.block AS audit_block, a.created_at AS audit_date,
                   ar.department, ar.remark AS ng_remark, ar.spec, ar.value AS ng_value
            FROM nonconformities n
            LEFT JOIN audits a ON a.id = n.audit_id
            LEFT JOIN audit_results ar ON ar.id = (
                SELECT ar2.id FROM audit_results ar2
                WHERE ar2.audit_id = n.audit_id AND ar2.stage = n.stage AND ar2.result = 'NG'
                ORDER BY ar2.id ASC LIMIT 1
            )
            WHERE $wSQL ORDER BY n.opened_at ASC
        ");
        $st2->execute($params);
        $ncs = $st2->fetchAll();
        /* Attach RCA manually */
        $rcaSt = $db->prepare(
            "SELECT * FROM rca_entries
             WHERE audit_code=? AND stage=? AND param=?
             ORDER BY id DESC LIMIT 1");
        foreach ($ncs as &$row) {
            try {
                $rcaSt->execute([$row['audit_code']??null, $row['stage'], $row['defect_type']]);
                $rca = $rcaSt->fetch();
                if ($rca) {
                    $row['rca_id']           = $rca['id'];
                    $row['root_cause']       = $rca['root_cause'];
                    $row['corrective_action']= $rca['corrective_action'];
                    $row['responsible']      = $rca['responsible'];
                    $row['defect_desc']      = $rca['defect_desc'];
                    $row['rca_due']          = $rca['due_date'];
                    $row['period_type']      = $rca['period_type'];
                    $row['rca_submitted_by'] = $rca['created_by'];
                }
            } catch (Throwable $e2) {}
        }
        unset($row);
    } catch (Throwable $e3) {}
}

/* ── KPI ─────────────────────────────────────────────────────────────────── */
try {
    $kpi = $db->query("
        SELECT
            COUNT(*)                               AS in_review,
            SUM(severity IN ('high','critical'))   AS high_sev,
            COUNT(DISTINCT n.line)                 AS lines_affected,
            COUNT(DISTINCT ar2.department)         AS depts_affected
        FROM nonconformities n
        LEFT JOIN audit_results ar2
               ON ar2.audit_id=n.audit_id AND ar2.stage=n.stage AND ar2.result='NG'
        WHERE n.status='in_review'
    ")->fetch();
} catch (Throwable $e) {
    $kpi = ['in_review'=>0,'high_sev'=>0,'lines_affected'=>0,'depts_affected'=>0];
}

/* ── Group by dept ───────────────────────────────────────────────────────── */
$grouped = [];
foreach ($ncs as $nc) {
    $dept = $nc['department'] ?: 'Unassigned';
    $grouped[$dept][] = $nc;
}
ksort($grouped);

/* ── Filter options ──────────────────────────────────────────────────────── */
$DEPTS     = ['Production','Material','Maintenance','Programming','Quality'];
