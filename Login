<?php
/* ============================================================================
 *  login.php — sign in. Verifies against the users table via auth.php.
 * ==========================================================================*/
require_once __DIR__ . '/includes/auth.php';
require_once __DIR__ . '/includes/helpers.php';

if (currentUser()) { 
    $dest = function_exists('post_login_redirect') ? post_login_redirect(currentUser()) : 'dashboard.php';
    header('Location: ' . $dest); exit;
}

$error = '';
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!csrf_check()) {
        $error = 'Session expired — please try again.';
    } else {
        $gen_id = trim($_POST['gen_id'] ?? '');
        $pass  = $_POST['password'] ?? '';
        if (login($gen_id, $pass)) {
            $dest = function_exists('post_login_redirect') ? post_login_redirect(currentUser()) : 'dashboard.php';
            header('Location: ' . $dest); exit;
        }
        $error = 'Invalid GEN ID or password.';
    }
}
$PAGE_TITLE = 'Sign in';
$ASSET = '';
include __DIR__ . '/includes/_head.php';
?>
