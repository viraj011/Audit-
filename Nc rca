<?php
/* ============================================================================
 *  nc_rca.php — Unified NC Follow-up & RCA Module
 *  ---------------------------------------------------------------------------
 *  Merges the old nc_followup / rca separation into one page.
 *
 *  FLOW:
 *  1. When audit is saved, save_audit() creates rows in `nonconformities`
 *     for every NG (already exists). This page links those NCs to rca_entries.
 *  2. Department heads see only NCs where department matches their role/dept.
 *  3. They fill Root Cause + Corrective Action + Status and save → rca_entries.
 *  4. PQC/Admin can Verify (mark closed) or Reject (sends back to open).
 *
 *  DB tables used (no schema changes — works with existing tables):
 *    - nonconformities  (nc_code, audit_id, line, stage, defect_type, severity, status)
 *    - audit_results    (department, remark columns — already added via updates.sql)
 *    - rca_entries      (full RCA data — auto-created by qats_auto_migrate)
 *    - audits           (for audit meta: model, shift, block, audit_code)
 * ===========================================================================*/

require_once __DIR__ . '/includes/auth.php';
require_once __DIR__ . '/includes/helpers.php';
require_once __DIR__ . '/includes/components.php';
require_once __DIR__ . '/includes/audit_functions.php';
requireLogin();

$db  = db();
$me  = currentUser();

// ── Dept / role detection ────────────────────────────────────────────────────
// In the real QATS users table there is no "department" column by default —
// the role name IS the department key. We treat can_admin roles as PQC.
$userRole    = strtolower($me['role']       ?? '');
$userRoleLabel = $me['role_label'] ?? '';
$isPQC       = !empty($me['can_admin'])
            || in_array($userRole, ['admin', 'pqc', 'quality', 'quality manager'], true);

// Department label to filter NCs (stored in audit_results.department)
$DEPTS = ['Production', 'Material', 'Maintenance', 'Programming', 'Quality'];

// Try to detect current user's department from their role_label
$userDept = '';
foreach ($DEPTS as $d) {
    if (stripos($userRoleLabel, $d) !== false) { $userDept = $d; break; }
}
// If no dept matched but they're not PQC, default to showing all (they pick in filter)

// ── Filters ──────────────────────────────────────────────────────────────────
$fStatus  = $_GET['status'] ?? 'open';          // open | closed | all
$fDept    = $_GET['dept']   ?? $userDept;
$fBlock   = $_GET['block']  ?? '';
$fLine    = $_GET['line']   ?? '';
$fStage   = $_GET['stage']  ?? '';
$fFrom    = $_GET['from']   ?? '';
$fTo      = $_GET['to']     ?? '';
$fPeriod  = in_array($_GET['period'] ?? '', ['daily','weekly','monthly']) ? $_GET['period'] : '';
$fSearch  = trim($_GET['q'] ?? '');

// ── Handle POST actions ───────────────────────────────────────────────────────
$errors = [];

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!csrf_check()) { $errors[] = 'Session expired — please resubmit.'; goto RENDER; }

    $action = $_POST['action'] ?? '';
    $ncId   = (int)($_POST['nc_id'] ?? 0);

    /* ── Save / update RCA entry ─────────────────────────────────────────── */
    if ($action === 'save_rca' && $ncId > 0) {

        // Load the NC to get line/stage/param/audit_code
        $nc = $db->prepare("SELECT n.*, a.audit_code, a.line AS audit_line, a.block, a.model
                             FROM nonconformities n
                             LEFT JOIN audits a ON a.id = n.audit_id
                             WHERE n.id = ? LIMIT 1");
        $nc->execute([$ncId]);
        $nc = $nc->fetch();

        if (!$nc) { $errors[] = 'NC not found.'; goto RENDER; }

        // Non-PQC: verify ownership via dept
        if (!$isPQC && $fDept) {
            // Check if the NG finding belongs to this dept (from audit_results)
            $deptCheck = $db->prepare(
                "SELECT COUNT(*) FROM audit_results ar
                 JOIN audits a ON a.id = ar.audit_id
                 WHERE a.id = ? AND ar.result = 'NG'
                   AND ar.stage = ? AND ar.department = ?");
            $deptCheck->execute([$nc['audit_id'], $nc['stage'], $fDept]);
            if (!(int)$deptCheck->fetchColumn()) {
                $errors[] = 'Access denied — this NC is not assigned to your department.';
                goto RENDER;
            }
        }

        $rootCause   = trim($_POST['root_cause']        ?? '');
        $corrAction  = trim($_POST['corrective_action'] ?? '');
        $responsible = trim($_POST['responsible']       ?? '');
        $defectDesc  = trim($_POST['defect_desc']       ?? '');
        $dueDate     = trim($_POST['due_date']          ?? '') ?: null;
        $periodType  = $_POST['period_type'] ?? 'daily';
        $periodDate  = match($periodType) {
            'weekly'  => date('Y-m-d', strtotime('monday this week', strtotime($_POST['period_date'] ?? date('Y-m-d')))),
            'monthly' => date('Y-m-01', strtotime($_POST['period_date'] ?? date('Y-m-d'))),
            default   => $_POST['period_date'] ?? date('Y-m-d'),
        };
        $newStatus   = $_POST['rca_status'] ?? 'open';
        if (!in_array($newStatus, ['open','in_progress','closed'], true)) $newStatus = 'open';

        // Upsert into rca_entries (keyed by nc_id stored in audit_code field)
        // We use audit_code + param + stage as the natural unique key
        $auditCode = $nc['audit_code'] ?? null;
        $line      = $nc['audit_line'] ?? $nc['line'];
        $block     = $nc['block'] ?? (function_exists('block_for_line') ? block_for_line($line) : null);

        // Check if an rca_entry already exists for this nc
        $existing = $db->prepare(
            "SELECT id FROM rca_entries
             WHERE audit_code = ? AND stage = ? AND param = ? LIMIT 1");
        $existing->execute([$auditCode, $nc['stage'], $nc['defect_type']]);
        $rcaId = $existing->fetchColumn();

        if ($rcaId) {
            $db->prepare("UPDATE rca_entries SET
                root_cause=?, corrective_action=?, responsible=?, defect_desc=?,
                due_date=?, status=?, period_type=?, period_date=?
                WHERE id=?")
               ->execute([$rootCause, $corrAction, $responsible, $defectDesc,
                          $dueDate, $newStatus, $periodType, $periodDate, $rcaId]);
        } else {
            $db->prepare("INSERT INTO rca_entries
                (audit_code, line, block, stage, param, defect_desc,
                 root_cause, corrective_action, responsible,
                 due_date, status, period_type, period_date, created_by)
                VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)")
               ->execute([$auditCode, $line, $block, $nc['stage'], $nc['defect_type'],
                          $defectDesc, $rootCause, $corrAction, $responsible,
                          $dueDate, $newStatus, $periodType, $periodDate,
                          $me['name'] ?? '']);
        }

        // If status = closed → close the NC too
        if ($newStatus === 'closed') {
            $db->prepare("UPDATE nonconformities SET status='closed', closed_at=NOW() WHERE id=?")
               ->execute([$ncId]);
        } elseif ($newStatus === 'in_progress') {
            $db->prepare("UPDATE nonconformities SET status='in_review' WHERE id=? AND status='open'")
               ->execute([$ncId]);
        }

        flash('RCA entry saved successfully.', 'success');
        header('Location: nc_rca.php?' . http_build_query(array_filter([
            'status'=>$fStatus,'dept'=>$fDept,'block'=>$fBlock,'line'=>$fLine,
            'stage'=>$fStage,'from'=>$fFrom,'to'=>$fTo,'period'=>$fPeriod,
        ])));
        exit;
    }

    /* ── PQC: Verify / close ─────────────────────────────────────────────── */
    if ($action === 'verify' && $isPQC && $ncId > 0) {
        $db->prepare("UPDATE nonconformities SET status='closed', closed_at=NOW() WHERE id=?")
           ->execute([$ncId]);
        // Also close linked rca_entry
        $nc2 = $db->prepare("SELECT n.*, a.audit_code FROM nonconformities n LEFT JOIN audits a ON a.id=n.audit_id WHERE n.id=?");
        $nc2->execute([$ncId]);
        $nc2 = $nc2->fetch();
        if ($nc2) {
            $db->prepare("UPDATE rca_entries SET status='closed' WHERE audit_code=? AND stage=? AND param=?")
               ->execute([$nc2['audit_code']??null, $nc2['stage'], $nc2['defect_type']]);
        }
        flash('NC verified and closed.', 'success');
        header('Location: nc_rca.php?' . http_build_query(array_filter(['status'=>$fStatus,'dept'=>$fDept,'block'=>$fBlock])));
        exit;
    }

    /* ── PQC: Reopen / reject ────────────────────────────────────────────── */
    if ($action === 'reopen' && $isPQC && $ncId > 0) {
        $db->prepare("UPDATE nonconformities SET status='open', closed_at=NULL WHERE id=?")
           ->execute([$ncId]);
        $reason = trim($_POST['reject_reason'] ?? '');
        $nc2 = $db->prepare("SELECT n.*, a.audit_code FROM nonconformities n LEFT JOIN audits a ON a.id=n.audit_id WHERE n.id=?");
        $nc2->execute([$ncId]);
        $nc2 = $nc2->fetch();
        if ($nc2) {
            $db->prepare("UPDATE rca_entries SET status='open', responsible=CONCAT(COALESCE(responsible,''),' [Rejected: ".addslashes($reason)."') WHERE audit_code=? AND stage=? AND param=?")
               ->execute([$nc2['audit_code']??null, $nc2['stage'], $nc2['defect_type']]);
        }
        flash('NC rejected and sent back for rework.', 'warning');
        header('Location: nc_rca.php?' . http_build_query(array_filter(['status'=>$fStatus,'dept'=>$fDept])));
        exit;
    }

    /* ── Bulk verify all in_review ───────────────────────────────────────── */
    if ($action === 'bulk_verify' && $isPQC) {
        $db->exec("UPDATE nonconformities SET status='closed', closed_at=NOW() WHERE status='in_review'");
        $db->exec("UPDATE rca_entries SET status='closed' WHERE status='in_progress'");
        flash('All in-review NCs verified and closed.', 'success');
        header('Location: nc_rca.php');
        exit;
    }
}
RENDER:

// ── Build NC query ────────────────────────────────────────────────────────────
$where = ['1=1'];
$p     = [];

// Status filter
if ($fStatus === 'open')   { $where[] = "n.status IN ('open','in_review')"; }
elseif ($fStatus === 'closed') { $where[] = "n.status = 'closed'"; }

// Dept filter: join audit_results to get department
// Non-PQC users only see their own dept's NGs
if (!$isPQC && $userDept) {
    $where[] = "EXISTS (
        SELECT 1 FROM audit_results ar2
        WHERE ar2.audit_id = n.audit_id
          AND ar2.stage = n.stage
          AND ar2.result = 'NG'
          AND ar2.department = ?
    )";
    $p[] = $userDept;
} elseif ($fDept !== '') {
    $where[] = "EXISTS (
        SELECT 1 FROM audit_results ar2
        WHERE ar2.audit_id = n.audit_id
          AND ar2.stage = n.stage
          AND ar2.result = 'NG'
          AND ar2.department = ?
    )";
    $p[] = $fDept;
}

if ($fBlock  !== '') { $where[] = 'a.block = ?';     $p[] = $fBlock; }
if ($fLine   !== '') { $where[] = 'n.line = ?';      $p[] = $fLine; }
if ($fStage  !== '') { $where[] = 'n.stage = ?';     $p[] = $fStage; }
if ($fFrom   !== '') { $where[] = 'DATE(n.opened_at) >= ?'; $p[] = $fFrom; }
if ($fTo     !== '') { $where[] = 'DATE(n.opened_at) <= ?'; $p[] = $fTo; }
if ($fSearch !== '') {
    $where[] = '(n.nc_code LIKE ? OR n.defect_type LIKE ? OR n.line LIKE ? OR a.audit_code LIKE ?)';
    $s = '%' . $fSearch . '%';
    array_push($p, $s, $s, $s, $s);
}

$sql = "
    SELECT
        n.*,
        a.audit_code, a.model, a.shift, a.block AS audit_block,
        a.pass_rate, a.created_at AS audit_date,
        ar.department, ar.remark AS ng_remark, ar.spec, ar.value AS ng_value,
        r.root_cause, r.corrective_action, r.responsible,
        r.defect_desc, r.due_date AS rca_due,
        r.status AS rca_status, r.period_type,
        r.id AS rca_id, r.created_by AS rca_by
    FROM nonconformities n
    LEFT JOIN audits a ON a.id = n.audit_id
    LEFT JOIN audit_results ar ON ar.audit_id = n.audit_id
        AND ar.stage = n.stage
        AND ar.result = 'NG'
        ORDER BY ar.id ASC
        LIMIT 1
    LEFT JOIN (
        SELECT re.*, ROW_NUMBER() OVER (PARTITION BY re.audit_code, re.stage, re.param ORDER BY re.id DESC) rn
        FROM rca_entries re
    ) r ON r.audit_code = a.audit_code
        AND r.stage = n.stage
        AND r.param = n.defect_type
        AND r.rn = 1
    WHERE " . implode(' AND ', $where) . "
    ORDER BY
        FIELD(n.status,'open','in_review','closed'),
        n.opened_at DESC
    LIMIT 300
";

// Fallback for MySQL < 8 (no ROW_NUMBER window function)
$ncs = [];
try {
    $st = $db->prepare($sql);
    $st->execute($p);
    $ncs = $st->fetchAll();
} catch (Throwable $e) {
    // Simpler fallback without window function
    $sql2 = "
        SELECT
            n.*,
            a.audit_code, a.model, a.shift, a.block AS audit_block,
            a.pass_rate, a.created_at AS audit_date,
            ar.department, ar.remark AS ng_remark, ar.spec, ar.value AS ng_value
        FROM nonconformities n
        LEFT JOIN audits a ON a.id = n.audit_id
        LEFT JOIN audit_results ar ON ar.audit_id = n.audit_id
            AND ar.stage = n.stage AND ar.result = 'NG'
        WHERE " . implode(' AND ', $where) . "
        ORDER BY FIELD(n.status,'open','in_review','closed'), n.opened_at DESC
        LIMIT 300
    ";
    try {
        $st2 = $db->prepare($sql2);
        $st2->execute($p);
        $ncs = $st2->fetchAll();
        // Manually fetch rca for each
        $rcaSt = $db->prepare(
            "SELECT * FROM rca_entries WHERE audit_code=? AND stage=? AND param=?
             ORDER BY id DESC LIMIT 1");
        foreach ($ncs as &$row) {
            try {
                $rcaSt->execute([$row['audit_code']??null, $row['stage'], $row['defect_type']]);
                $rca = $rcaSt->fetch();
                $row['root_cause']       = $rca['root_cause']       ?? null;
                $row['corrective_action']= $rca['corrective_action'] ?? null;
                $row['responsible']      = $rca['responsible']       ?? null;
                $row['defect_desc']      = $rca['defect_desc']       ?? null;
                $row['rca_due']          = $rca['due_date']          ?? null;
                $row['rca_status']       = $rca['status']            ?? null;
                $row['period_type']      = $rca['period_type']       ?? null;
                $row['rca_id']           = $rca['id']                ?? null;
                $row['rca_by']           = $rca['created_by']        ?? null;
            } catch (Throwable $e2) {}
        }
        unset($row);
    } catch (Throwable $e3) {
        $errors[] = 'Query error: ' . $e3->getMessage();
    }
}

// ── KPI counts ────────────────────────────────────────────────────────────────
// Always count across the full dept scope (not just current filter)
$kpiWhere = $isPQC ? '1=1' : "EXISTS (
    SELECT 1 FROM audit_results ar3
    JOIN audits a3 ON a3.id = ar3.audit_id
    WHERE ar3.audit_id = n.audit_id AND ar3.stage = n.stage
      AND ar3.result='NG' AND ar3.department=" . $db->quote($userDept) . "
)";
try {
    $kpi = $db->query("
        SELECT
            COUNT(*)                                                  AS total,
            SUM(n.status='open')                                      AS open_count,
            SUM(n.status='in_review')                                 AS in_review,
            SUM(n.status='closed')                                    AS closed_count,
            SUM(n.severity IN ('high','critical'))                    AS high_sev,
            SUM(n.status != 'closed' AND n.opened_at < DATE_SUB(NOW(), INTERVAL 7 DAY)) AS overdue
        FROM nonconformities n WHERE $kpiWhere
    ")->fetch(PDO::FETCH_ASSOC);
} catch (Throwable $e) {
    $kpi = ['total'=>0,'open_count'=>0,'in_review'=>0,'closed_count'=>0,'high_sev'=>0,'overdue'=>0];
}

// ── Group NCs by stage for display ───────────────────────────────────────────
$byStage = [];
foreach ($ncs as $nc) {
    $byStage[$nc['stage'] ?? 'General'][] = $nc;
}

// ── Lines + Stages for filters ────────────────────────────────────────────────
$lines  = []; try { $lines  = $db->query("SELECT name FROM production_lines WHERE active=1 ORDER BY sort_order, name")->fetchAll(PDO::FETCH_COLUMN); } catch(Throwable $e){}
$stages = []; try { $stages = $db->query("SELECT DISTINCT stage FROM nonconformities WHERE stage IS NOT NULL ORDER BY stage")->fetchAll(PDO::FETCH_COLUMN); } catch(Throwable $e){}

// ── Pending in-review count (for bulk verify button badge) ───────────────────
$inReviewCount = 0;
try { $inReviewCount = (int)$db->query("SELECT COUNT(*) FROM nonconformities WHERE status='in_review'")->fetchColumn(); } catch(Throwable $e){}

$PAGE_TITLE   = 'NC Follow-up & RCA';
$PAGE_HEADING = 'NC Follow-up & RCA';
$PAGE_SUB     = $isPQC
    ? 'All departments · Verify and close NG findings'
    : 'Department: ' . ($userDept ?: $userRoleLabel) . ' · Enter root cause and corrective action';
$ACTIVE = 'nc_rca';
$ASSET  = '';
include __DIR__ . '/includes/_head.php';
?>
