<script>
/* ── Toggle RCA accordion ──────────────────────────────────────── */
function toggleRCA(id) {
    var body   = document.getElementById('rca-body-' + id);
    var toggle = document.getElementById('rca-toggle-' + id);
    if (!body) return;
    var isOpen = body.classList.contains('open');
    body.classList.toggle('open');
    if (toggle) toggle.classList.toggle('open', !isOpen);
    if (!isOpen) body.scrollIntoView({behavior:'smooth', block:'nearest'});
}

/* Auto-open RCA for open NCs with no RCA yet (department view only) */
<?php if (!$isPQC): ?>
document.querySelectorAll('.nc-row.status-open').forEach(function(row) {
    var id = row.id.replace('nc-', '');
    var hasRCA = row.querySelector('.rca-existing');
    if (!hasRCA) {
        // Don't auto-open — just highlight the toggle button
        var btn = document.getElementById('rca-toggle-' + id);
        if (btn) btn.style.borderColor = 'var(--red)';
    }
});
<?php endif; ?>

/* ── Toggle stage group ───────────────────────────────────────── */
function toggleStage(header) {
    var body    = header.nextElementSibling;
    var chevron = header.querySelector('.fa-chevron-down, .fa-chevron-up');
    body.style.display = (body.style.display === 'none') ? '' : 'none';
    if (chevron) {
        chevron.classList.toggle('fa-chevron-down');
        chevron.classList.toggle('fa-chevron-up');
    }
}

/* ── Reject modal ────────────────────────────────────────────── */
function openRejectModal(id) {
    document.getElementById('rejectNcId').value = id;
    document.getElementById('rejectModal').classList.add('show');
    document.getElementById('rejectBackdrop').classList.add('show');
}
function closeRejectModal() {
    document.getElementById('rejectModal').classList.remove('show');
    document.getElementById('rejectBackdrop').classList.remove('show');
}

/* Auto-dismiss success alerts */
setTimeout(function() {
    document.querySelectorAll('.alert-success').forEach(function(a) {
        a.style.transition = 'opacity .5s';
        a.style.opacity = '0';
        setTimeout(function(){ a.remove(); }, 500);
    });
}, 4000);
</script>
